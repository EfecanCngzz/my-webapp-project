{
    "info": {
        "name": "Tasks CRUD API Collection (with Smoke Tests)",
        "description": "A collection for the Tasks CRUD API with embedded smoke tests.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Create Task",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 201\", function () {",
                            "    pm.response.to.have.status(201);",
                            "});",
                            "",
                            "pm.test(\"Response contains task details\", function () {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData).to.be.an(\"object\");",
                            "    pm.expect(jsonData).to.have.property(\"id\");",
                            "    pm.expect(jsonData).to.have.property(\"title\");",
                            "    pm.expect(jsonData).to.have.property(\"completed\");",
                            "",
                            "    var reqBody = JSON.parse(pm.request.body.raw);",
                            "    pm.expect(jsonData.title).to.eql(reqBody.title);",
                            "    pm.expect(jsonData.completed).to.eql(reqBody.completed);",
                            "    pm.expect(jsonData.id).to.be.a(\"number\").and.to.be.above(0);",
                            "",
                            "    if (jsonData.id) {",
                            "        pm.collectionVariables.set(\"taskId\", jsonData.id);",
                            "    }",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"title\": \"Buy groceries - from Postman\",\n  \"completed\": false\n}"
                },
                "url": {
                    "raw": "http://localhost:8080/my-webapp-project/api/tasks",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "my-webapp-project",
                        "api",
                        "tasks"
                    ]
                }
            }
        },
        {
            "name": "2. Get All Tasks",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "pm.test(\"Response is an array and contains created task\", function () {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData).to.be.an(\"array\");",
                            "    var taskId = pm.collectionVariables.get(\"taskId\");",
                            "    if (taskId) {",
                            "        var found = jsonData.find(task => task.id == taskId);",
                            "        pm.expect(found).to.not.be.undefined;",
                            "    }",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "http://localhost:8080/my-webapp-project/api/tasks",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "my-webapp-project",
                        "api",
                        "tasks"
                    ]
                }
            }
        },
        {
            "name": "3. Get Task by ID",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "pm.test(\"Check task ID and properties\", function () {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData).to.have.property(\"title\");",
                            "    pm.expect(jsonData).to.have.property(\"completed\");",
                            "    var expectedId = pm.collectionVariables.get(\"taskId\");",
                            "    if(expectedId) {",
                            "        pm.expect(jsonData.id.toString()).to.eql(expectedId.toString());",
                            "    }",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "http://localhost:8080/my-webapp-project/api/tasks/{{taskId}}",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "my-webapp-project",
                        "api",
                        "tasks",
                        "{{taskId}}"
                    ]
                }
            }
        },
        {
            "name": "4. Update Task",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "pm.test(\"Fields updated correctly\", function () {",
                            "    var jsonData = pm.response.json();",
                            "    var reqBody = JSON.parse(pm.request.body.raw);",
                            "    pm.expect(jsonData.title).to.eql(reqBody.title);",
                            "    pm.expect(jsonData.completed).to.eql(reqBody.completed);",
                            "    ",
                            "    var expectedId = pm.collectionVariables.get(\"taskId\");",
                            "    if(expectedId) {",
                            "        pm.expect(jsonData.id.toString()).to.eql(expectedId.toString());",
                            "    }",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "PUT",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"title\": \"Buy groceries - updated\",\n  \"completed\": true\n}"
                },
                "url": {
                    "raw": "http://localhost:8080/my-webapp-project/api/tasks/{{taskId}}",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "my-webapp-project",
                        "api",
                        "tasks",
                        "{{taskId}}"
                    ]
                }
            }
        },
        {
            "name": "5. Delete Task",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "pm.test(\"Success message returned\", function () {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.message).to.eql(\"Task deleted successfully\");",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "DELETE",
                "header": [],
                "url": {
                    "raw": "http://localhost:8080/my-webapp-project/api/tasks/{{taskId}}",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "my-webapp-project",
                        "api",
                        "tasks",
                        "{{taskId}}"
                    ]
                }
            }
        }
    ],
    "variable": [
        {
            "key": "taskId",
            "value": "1"
        }
    ]
}
<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
 "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
 "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
  <!-- Suppress standard Java naming conventions that conflict with style guides -->
  <suppress checks="AbbreviationAsWordInName" files="TaskDAO\.java" lines="13"/>
  
  <!-- Suppress Indentation warnings for method bodies that use 4 spaces -->
  <suppress checks="Indentation" files=".*Servlet\.java" />
  <suppress checks="Indentation" files=".*DAO\.java" />
  
  <!-- Allow longer lines for method signatures with many parameters -->
  <suppress checks="LineLength" files=".*Servlet\.java" lines="67,93,128"/>
  
  <!-- Suppress missing Javadoc for test methods -->
  <suppress checks="MissingJavadocMethod" files=".*Test\.java" />
  
  <!-- Allow package-private classes without Javadoc -->
  <suppress checks="MissingJavadocType" files=".*" />
</suppressions>
